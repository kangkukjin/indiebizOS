          },
          "count_per_month": {
            "type": "integer",
            "default": 30,
            "description": "월별 최대 건수"
          }
        },
        "required": [
          "region_code",
          "start_month"
        ]
      }
    },
    {
      "name": "house_rent_price",
      "description": "단독/다가구 주택 전월세 실거래가를 조회합니다.\n\n## 사용 시점\n- 단독주택 임대료 파악\n- 다가구 수익률 분석\n\n## 반환 정보\n- 거래일, 건물유형, 면적, 보증금, 월세",
      "input_schema": {
