{
  "id": "visualization",
  "name": "Visualization Tools",
  "description": "데이터 시각화 도구. 라인차트, 막대차트, 파이차트, 산점도, 히트맵, 캔들스틱 등 다양한 차트를 PNG/HTML로 생성합니다. 데이터 분석 결과 시각화, 주가 차트, 비교 그래프, 대시보드 제작에 활용.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "chart",
      "description": "차트 종류 자동 분기 — chart_type으로 line/bar/pie/scatter/heatmap/candlestick/multi 선택. 종류별 데이터 형식은 해당 개별 차트 도구의 설명을 참조.",
      "input_schema": {
        "type": "object",
        "properties": {
          "chart_type": {
            "type": "string",
            "enum": [
              "line",
              "bar",
              "pie",
              "scatter",
              "heatmap",
              "candlestick",
              "multi"
            ],
            "description": "차트 종류. 기본값 line."
          },
          "data": {
            "type": "array",
            "description": "차트 데이터. 형식은 chart_type에 따라 다름 ([{x,y}] / [{label,value}] / [{x,y,size}] / 등)",
            "items": {
              "type": "object"
            }
          },
          "data_file": {
            "type": "string",
            "description": "데이터 파일 경로 (JSON/CSV). data 대신 사용."
          },
          "title": {
            "type": "string",
            "description": "차트 제목"
          },
          "x_label": {
            "type": "string"
          },
          "y_label": {
            "type": "string"
          },
          "series_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "output_format": {
            "type": "string",
            "enum": [
              "png",
              "html"
            ],
            "description": "기본값 png"
          },
          "output_path": {
            "type": "string",
            "description": "출력 파일 경로 (선택)"
          },
          "charts": {
            "type": "array",
            "description": "multi 차트 전용 — 여러 서브차트 배열",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  ]
}