{
  "name": "indiebiz-os",
  "productName": "IndieBiz OS",
  "version": "0.1.0",
  "description": "AI Agent Platform - Operating System Level",
  "author": "nicekukjin",
  "repository": {
    "type": "git",
    "url": "https://github.com/kangkukjin/indiebizOS.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "predist:filter": "python3 ../scripts/build_core_manifest.py",
    "dist:filter": "python3 ../scripts/build_dist_filter.py",
    "electron:build": "npm run dist:filter && vite build && electron-builder",
    "electron:build:win": "npm run dist:filter && vite build && electron-builder --win",
    "electron:build:mac": "npm run dist:filter && vite build && electron-builder --mac",
    "electron:build:linux": "npm run dist:filter && vite build && electron-builder --linux",
    "electron:preview": "vite build && electron .",
    "prepare:python:win": "node scripts/prepare-python-win.js",
    "prepare:python:mac": "node scripts/prepare-python-mac.js",
    "prepare:node:win": "node scripts/prepare-node-win.js",
    "prepare:runtime:win": "npm run prepare:python:win && npm run prepare:node:win"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.indiebiz.app",
    "productName": "IndieBiz",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.env",
          "!.env.*",
          "!data/**",
          "!tokens/**",
          "!**/*.db",
          "!**/*.db-shm",
          "!**/*.db-wal",
          "!**/credentials*.json",
          "!**/*credential*.json",
          "!**/*.pem",
          "!**/*.key",
          "!**/nostr_keys/**",
          "!__pycache__/**",
          "!**/__pycache__/**",
          "!*.pyc",
          "!**/*.pyc",
          "!venv/**",
          "!.DS_Store",
          "!**/.DS_Store"
        ]
      },
      {
        "from": "../data",
        "to": "data",
        "filter": [
          "**/*",
          "!system_ai_config.json",
          "!midtier_ai_config.json",
          "!lightweight_ai_config.json",
          "!unconscious_ai_config.json",
          "!model_gear.json",
          "!system_ai_memory.db",
          "!claude_code_config.json",
          "!claude_code_sessions.json",
          "!conversations.db",
          "!**/conversations.db",
          "!tokens/**",
          "!packages/outputs/**",
          "!**/*.bak",
          "!**/*.bak*",
          "!switches.json",
          "!event_triggers.json",
          "!ai_desktop_map.json",
          "!my_profile.txt",
          "!device_id.txt",
          "!business.db",
          "!multi_chat.db",
          "!calendar_events.json",
          "!plan.md",
          "!gomoku_board.png",
          "!system_ai_role.txt",
          "!system_ai_memo.txt",
          "!launcher_web_config.json",
          "!nas_config.json",
          "!tunnel_config.json",
          "!location_cache.json",
          "!world_pulse.db",
          "!indiebiz.db",
          "!SKILLs/skills.db",
          "!business_images/**",
          "!packages/installed/tools/web/sites.json",
          "!**/credentials*.json",
          "!**/*credential*.json",
          "!**/*.pem",
          "!**/*.key",
          "!**/nostr_keys/**",
          "!browser_cookies/**",
          "!outputs/**",
          "!health/**",
          "!system_ai_prompts/**",
          "!thumbnail_cache/**",
          "!storage_scans/**",
          "!packages/system_ai_state/**",
          "!packages/available/**",
          "!packages/photo_scans/**",
          "!packages/storage_index.db",
          "!packages/installed/photo_index.db",
          "!packages/installed/tools/**/*.db",
          "!packages/installed/tools/**/*.db-shm",
          "!packages/installed/tools/**/*.db-wal",
          "!packages/installed/tools/**/*.db.bak",
          "!packages/installed/tools/**/_temp_*",
          "!**/*_index.db",
          "!packages/installed/tools/remotion-video/remotion_project/node_modules/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.DS_Store",
          "!__GEN_START__",
          "!**/.fuse_hidden*",
          "!**/.DS_Store",
          "!**/*.bak",
          "!**/*.bak.*",
          "!**/*.bak_*",
          "!**/*.backup*",
          "!**/*.bak-*",
          "!*.md",
          "!*.html",
          "!*.png",
          "!*.sql",
          "!*.jsonl",
          "!packages/installed/extensions/ai-agent/**",
          "!__GEN_END__"
        ]
      },
      {
        "from": "../templates",
        "to": "templates"
      }
    ],
    "extraFiles": [
      {
        "from": "../INSTALL_DEPENDENCIES.md",
        "to": "INSTALL_DEPENDENCIES.md"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "extraResources": [
        {
          "from": "../build/python-mac",
          "to": "runtime/python"
        },
        {
          "from": "../build/node-mac",
          "to": "runtime/node"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "../build/python-win",
          "to": "runtime/python"
        },
        {
          "from": "../build/node-win",
          "to": "runtime/node"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IndieBiz"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
