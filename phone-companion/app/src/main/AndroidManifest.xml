<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 송신측([limbs:phone]{op:vibrate}) — 설치시 자동 부여되는 일반 권한 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 위치 ([sense:here] 온디맨드 1회 조회 — 상시/백그라운드 수집 안 함) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- 마이크 ([sense:listen] 온디맨드 받아쓰기/녹음) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 카메라 ([sense:see] 온디맨드 촬영) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- 미디어 라이브 질의 ([self:photo] — MediaStore 색인 직접). Android 13+ 분리 권한. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- 사진 GPS(EXIF) 원본 접근 — 위치 질의(has_gps) 일 때만 사용. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <application
        android:name=".App"
        android:label="IndieBiz"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:allowBackup="true">

        <!-- 진입 화면 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 런처(앱/수동/자율주행) WebView 표면 -->
        <activity
            android:name=".LauncherActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- 알림 캡처 서비스 제거됨(2026-06-22) — 폰 알림 수집/중계 폐기.
             과거: NotificationListenerService 가 모든 알림을 가로채 로컬 JSONL 적재(+옛 Nostr 푸시).
             외부 전송은 2026-06-15 제거됐으나 로컬 수집이 남아 있어 완전 폐기. [sense:phone] 알림은 빈 결과. -->

        <!-- [limbs:android] 폰 네이티브 화면 조작 (AccessibilityService) — USB-ADB 없이 자기 화면 독해·터치 -->
        <service
            android:name=".PhoneAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- 상주용 포그라운드 서비스 (프로세스 생존 유지) -->
        <service
            android:name=".AgentForegroundService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="indiebiz_phone_agent_relay" />
        </service>

        <!-- 재부팅 후 상주 복원 -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
