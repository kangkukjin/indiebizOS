#!/usr/bin/env bash
# IBL 어휘 정합성 pre-commit 훅
#
# 다음 파일이 스테이징될 때만 `build_ibl_nodes.py --check` 를 실행:
#   - data/ibl_nodes_src/*.yaml          (src 편집)
#   - data/packages/installed/**/ibl_actions.yaml (패키지 어휘 fragment — aliases/ops/tool_json)
#   - data/packages/installed/**/tool.json   (op enum/default — 빌드 파생물)
#   - data/packages/installed/**/handler.py  (op 분기 substring + 코퍼스 param 정합)
#   - data/training/*.json                   (코퍼스 param 정합)
#   - scripts/build_ibl_nodes.py             (빌더 자체)
# (2026-07-03: 파라미터 별칭이 ibl_routing.ACTION_PARAM_ALIASES → 어휘 데이터의
#  aliases: 블록으로 이주 — ibl_routing.py 트리거를 ibl_actions.yaml 로 교체)
#
# 검사 실패 시 커밋 차단. `--no-verify` 로 우회 가능하지만 권장 X.
#
# 설치:
#   ln -sf "$(pwd)/scripts/git-hooks/pre-commit" .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit  (이미 +x 면 생략 가능)
set -euo pipefail

# 스테이징된 파일 목록.
staged=$(git diff --cached --name-only --diff-filter=ACMR)

# 검사 트리거 — 위 4종 중 하나라도 스테이지되어 있으면 실행.
# (2026-07-18: 빌더가 iblbuild_* 형제 모듈로 분할 — 가드 본체 편집도 트리거에 포함)
if echo "$staged" | grep -qE '^(data/ibl_nodes_src/.*\.yaml|data/packages/installed/.*/ibl_actions\.yaml|data/packages/installed/.*/tool\.json|data/packages/installed/.*/handler\.py|data/training/.*\.json|scripts/(build_ibl_nodes|iblbuild_[a-z]+)\.py)$'; then
  repo_root=$(git rev-parse --show-toplevel)
  echo "[pre-commit] IBL 정합성 검사 실행..."
  if ! python3 "$repo_root/scripts/build_ibl_nodes.py" --check; then
    echo "" >&2
    echo "[pre-commit] IBL 검증 실패 — 커밋 차단." >&2
    echo "[pre-commit]   • src 편집 후 \`python3 scripts/build_ibl_nodes.py\` 재실행하여 ibl_nodes.yaml 갱신" >&2
    echo "[pre-commit]   • 검증 실패 항목은 위 로그 참조" >&2
    echo "[pre-commit]   • 정말로 우회하려면 \`git commit --no-verify\` (권장 X)" >&2
    exit 1
  fi
  echo "[pre-commit] IBL 정합성 OK ✓"
fi

# 폰(제약된 몸) 엔진 번들 매니페스트가 backend 변경에 맞게 최신인지 — 드리프트 게이트.
# backend/*.py 나 몸 프로파일이 스테이징되면 build_body_bundle.py --check 로 파생본 일치 확인.
if echo "$staged" | grep -qE '^(backend/.*\.py|data/bodies/.*\.json|scripts/build_body_bundle\.py)$'; then
  repo_root=$(git rev-parse --show-toplevel)
  echo "[pre-commit] 몸 번들 파생 검사 실행..."
  if ! python3 "$repo_root/scripts/build_body_bundle.py" android --check; then
    echo "" >&2
    echo "[pre-commit] 폰 엔진 번들이 backend 변경에 뒤처짐 — 커밋 차단." >&2
    echo "[pre-commit]   • \`python3 scripts/build_body_bundle.py android\` 재실행하여 매니페스트 갱신" >&2
    echo "[pre-commit]   • 새 backend 모듈이 폰 비호환이면 data/bodies/android.json 의 absent_packages/force_exclude 에 사유와 함께 선언" >&2
    exit 1
  fi
  echo "[pre-commit] 몸 번들 파생 OK ✓"
fi

# 의식 출력 스키마 이름 드리프트 — 프롬프트 응답 형식(생산자)이나 소비처 코드가 스테이징되면
# 생산자↔소비처 키 정합을 검사(개명 시 highlight_actions/hint 무성음 누락 방지, 4번째 층).
if echo "$staged" | grep -qE '^(data/common_prompts/consciousness_prompt\.md|backend/(prompt_builder|agent_cognitive|consciousness_agent)\.py|scripts/consciousness_schema_check\.py)$'; then
  repo_root=$(git rev-parse --show-toplevel)
  echo "[pre-commit] 의식 출력 스키마 정합 검사 실행..."
  if ! python3 "$repo_root/scripts/consciousness_schema_check.py"; then
    echo "" >&2
    echo "[pre-commit] 의식 출력 스키마 드리프트 — 커밋 차단." >&2
    echo "[pre-commit]   • 소비처가 프롬프트 미선언 키를 읽음(항상 빈 값=조언 유실)." >&2
    echo "[pre-commit]   • 소비처를 정본 키로 정렬하거나 consciousness_prompt.md 응답 형식에 키를 선언." >&2
    echo "[pre-commit]   • 우회: \`git commit --no-verify\` (권장 X)" >&2
    exit 1
  fi
  echo "[pre-commit] 의식 출력 스키마 정합 OK ✓"
fi

# 표준 코어 매니페스트 드리프트 — 패키지/앱/중앙어휘가 추가·제거되면 core_manifest.json 이
# 배포 집합(git 추적)과 어긋날 수 있다. 코어/사용자 경계의 단일 진실이므로 stale 커밋 차단.
if echo "$staged" | grep -qE '^(data/packages/(installed|not_installed)/[^/]+/[^/]+/|data/instruments/.*\.yaml|data/ibl_nodes_src/.*\.yaml|scripts/build_core_manifest\.py|scripts/build_dist_filter\.py|frontend/package\.json)'; then
  repo_root=$(git rev-parse --show-toplevel)
  echo "[pre-commit] 표준 코어 매니페스트 검사 실행..."
  if ! python3 "$repo_root/scripts/build_core_manifest.py" --check; then
    echo "" >&2
    echo "[pre-commit] core_manifest.json 이 배포 집합과 불일치 — 커밋 차단." >&2
    echo "[pre-commit]   • \`python3 scripts/build_core_manifest.py\` 재실행하여 매니페스트 갱신 후 스테이지" >&2
    echo "[pre-commit]   • 이 매니페스트는 코어/사용자(앱·어휘) 경계의 단일 진실 — 업데이터가 참조함" >&2
    echo "[pre-commit]   • 우회: \`git commit --no-verify\` (권장 X)" >&2
    exit 1
  fi
  echo "[pre-commit] 표준 코어 매니페스트 OK ✓"
  # 설치 파일 필터도 매니페스트 주도로 최신인지 (개인 앱·패키지가 배포에 새지 않게)
  echo "[pre-commit] 설치 파일 필터 검사 실행..."
  if ! python3 "$repo_root/scripts/build_dist_filter.py" --check; then
    echo "" >&2
    echo "[pre-commit] package.json 설치필터가 매니페스트와 불일치 — 커밋 차단." >&2
    echo "[pre-commit]   • \`python3 scripts/build_dist_filter.py\` 재실행 후 스테이지" >&2
    echo "[pre-commit]   • 비-코어 패키지/앱이 설치 파일로 새는 걸 막는 매니페스트 주도 필터" >&2
    echo "[pre-commit]   • 우회: \`git commit --no-verify\` (권장 X)" >&2
    exit 1
  fi
  echo "[pre-commit] 설치 파일 필터 OK ✓"
fi

exit 0
